FROM python:3.12-slim
COPY --from=ghcr.io/astral-sh/uv:0.9.6 /uv /uvx /bin/

# The slim image installs NO OS packages. It previously pulled in git + curl,
# but needs neither: the slim build excludes the `code-search` group (the only
# git-sourced dep, llama-cpp-python), so `uv sync` needs no git, and the server
# talks to plainsight-api over httpx — not curl — with httpGet/tcpSocket probes.
# Dropping them clears three CRITICAL SCC findings by removal (no apt upgrade
# needed): git's transitive `perl` (CVE-2026-42496, CVE-2026-8376 — unfixed in
# Debian trixie) and curl's transitive `libssh2` (CVE-2026-55200). Only essential
# `perl-base` remains (not SCC-flagged). (PLAT-1259)

WORKDIR /app

# Copy lockfile + manifest first (cache deps layer when only source changes)
COPY pyproject.toml README.md ./

# Stub out code-context so uv can resolve the workspace source path,
# but without its [tool.uv.sources] that trigger a slow git clone
RUN mkdir -p code-context && cat > code-context/pyproject.toml <<'STUB'
[project]
name = "code-context"
version = "0.1.0"
requires-python = ">=3.10,<3.13"
dependencies = []

[build-system]
requires = ["uv_build>=0.9.6,<0.10.0"]
build-backend = "uv_build"
STUB

# Slim build: no code-context, no code search indexes, no ML dependencies
ENV ENABLE_CODE_SEARCH=false
# Fail fast at startup if no auth token is available -- without code search
# the server would otherwise silently serve zero tools.
ENV REQUIRE_AUTH=true

# Install deps first (cached unless pyproject.toml or uv.lock change)
RUN uv sync --no-dev --no-install-workspace

# Now copy source (this layer invalidates on code changes)
COPY src/ src/

# Install the workspace package itself (fast — deps already cached)
RUN uv sync --no-dev

RUN rm -rf code-context/

CMD ["uv", "run", "--no-sync", "serve"]
